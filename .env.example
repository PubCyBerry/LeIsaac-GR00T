# docker-compose 가 참조하는 환경 변수.
# =============================================================================
#
# 사용법:
#   cp .env.example .env
#   # 아래 값들을 실제 환경에 맞게 수정하세요
#   docker compose --env-file .env -f docker/docker-compose.yaml up teleop
#
# ■ Windows 11 USB 포트 확인 방법
#   PowerShell (관리자):
#     usbipd list
#     usbipd attach --wsl --busid <BUS_ID>
#   WSL2 터미널:
#     ls /dev/ttyUSB*     # → 예: /dev/ttyUSB0, /dev/ttyUSB1
#     ls /dev/ttyACM*     # Feetech이 ACM으로 잡히는 경우
#
# ■ 모드별 필수 변수 요약
#   teleop            : TELEOP_PORT ROBOT_PORT 카메라 변수 일체
#   record            : teleop 변수 전체 + HF_DATASET_REPO_ID SINGLE_TASK ...
#   replay            : ROBOT_PORT + HF_DATASET_REPO_ID EPISODE_INDEX
#   calibrate         : CALIBRATE_TARGET + (LEADER or FOLLOWER) PORT
#   setup-motors      : CALIBRATE_TARGET + (LEADER or FOLLOWER) PORT
#   find-joint-limits : TELEOP_PORT ROBOT_PORT
#   dataset-viz       : HF_DATASET_REPO_ID EPISODE_INDEX
#   train / eval      : 인자를 CLI 에 직접 전달 (env var 불필요)
# =============================================================================

# ── HuggingFace Hub ───────────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens 에서 발급 (write 권한 필요)
HF_TOKEN=
HF_USER=

# ── Weights & Biases ──────────────────────────────────────────────────────────
WANDB_API_KEY=

# ── 로봇 ID ──────────────────────────────────────────────────────────────
TELEOP_ID=so101_teleop
ROBOT_ID=so101_robot

# ── Arm 직렬 포트 ──────────────────────────────────────────────────────────────
# Leader/Follower Arm 이 연결된 WSL2/Linux 장치 경로
# CH343 칩이 cdc_acm 드라이버로 ttyACM* 에 잡힘 (ttyUSB 아님 주의)
TELEOP_PORT=/dev/ttyACM0
ROBOT_PORT=/dev/ttyACM1

# ── 카메라 디바이스 경로 ────────────────────────────────────────────────────────
# UVC 카메라: 캡처 노드(짝수)와 메타데이터 노드(홀수) 쌍으로 존재
# belly cam — 전면부 고정 시점 (/dev/video0 캡처 노드)
BELLY_CAM_PORT=/dev/video0
BELLY_CAM_META_PORT=/dev/video1

# wrist cam — 손목 장착 시점 (/dev/video2 캡처 노드)
WRIST_CAM_PORT=/dev/video2
WRIST_CAM_META_PORT=/dev/video3

# ── OpenCV camera_index ────────────────────────────────────────────────────────
# cv2.VideoCapture(index) 에 전달되는 값 / /dev/videoN → index = N
BELLY_CAM_INDEX=0
WRIST_CAM_INDEX=2

# ── 카메라 해상도 / FPS ────────────────────────────────────────────────────────
# 해상도 확인: v4le-ctl --list-formats-ext
# Integrated_Webcam_HD 지원: 640x480@25fps, 1280x720@30fps(MJPEG)
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=25
# 카메라 warmup 대기 시간(초) — WSL2/Docker에서 UVC 초기화에 1초 이상 소요
# TimeoutError: Timed out waiting for frame 발생 시 이 값을 늘릴 것 (권장: 5초)
CAM_WARMUP_S=5
# 카메라 fourcc 
CAM_FOURCC=MJPG

# ── 기기 타입 (calibrate / setup-motors / find-joint-limits) ──────────────────
# 로봇 타입: so101_follower | so100_follower | bi_so100_follower | ...
ROBOT_TYPE=so101_follower
# 텔레옵 타입: so101_leader | so100_leader | ...
TELEOP_TYPE=so101_leader

# calibrate / setup-motors 대상: robot (팔로워 암) | teleop (리더 암)
CALIBRATE_TARGET=robot

# ── Display 설정 ─────────────────────────────────────────────────────────────
# rerun viewer
# docker에서 실행할 경우, DISPLAY_IP=host.docker.internal
DISPLAY_DATA=false
DISPLAY_IP=host.docker.internal
DISPLAY_PORT=9876

# ── lerobot-teleoperate  ─────────────────────────────────────────────────
# 추가 lerobot-teleoperate 인자
TELEOP_EXTRA_ARGS="
    --display_data=${DISPLAY_DATA} 
    --display_ip=${DISPLAY_IP} 
    --display_port=${DISPLAY_PORT}
"

# ── lerobot-record ───────────────────────────────────────────────────────────────
# 에피소드당 작업 설명 (lerobot-record --dataset.single_task)
SINGLE_TASK="pick and place"
# HF Hub 리포지토리 ID: '{hf_username}/{dataset_name}'
# record / replay / dataset-viz 모드에서 공통으로 사용
HF_DATASET_REPO_ID=${HF_USER}/${SINGLE_TASK}

# 수집할 에피소드 수 (--dataset.num_episodes)
NUM_EPISODES=10

# 에피소드 1회 녹화 시간(초) (--dataset.episode_time_s)
EPISODE_TIME_S=60

# 에피소드 간 환경 초기화 대기 시간(초) (--dataset.reset_time_s)
RESET_TIME_S=10

# 데이터셋 저장 fps (--dataset.fps) — teleop fps(CAM_FPS) 와 독립적으로 설정 가능
RECORD_FPS=60

# HF Hub 업로드 여부: true | false (--dataset.push_to_hub)
PUSH_TO_HUB=false

# 데이터셋 저장 경로(--dataset.root)
DATA_ROOT=/workspace/datasets/${SINGLE_TASK}

# 사전학습 체크포인트 경로/Hub ID(--policy.path)
POLICY_PATH= 

# 녹화중 실시간 데이터 스트리밍 여부
STREAM_DATA=true

# 인코더 인스턴스당 스레드 개수, None이면 vcoded가 알아서 결정
ENCODER_THREADS=None

# 추가 lerobot-record 인자 (공백 구분 문자열)
# 예: RECORD_EXTRA_ARGS=--resume=true --display_data=false
RECORD_EXTRA_ARGS="
    --display_data=${DISPLAY_DATA} 
    --display_ip=${DISPLAY_IP} 
    --display_port=${DISPLAY_PORT} 
    --dataset.root=${DATA_ROOT} 
    --dataset.vcodec=auto 
    --dataset.streaming_encoding=${STREAM_DATA} 
    --dataset.encoder_threads=${ENCODER_THREADS} 
    --play_sounds=false
"

# ── replay 설정 ───────────────────────────────────────────────────────────────
# 재생할 에피소드 인덱스 (0-based, --dataset.episode)
EPISODE_INDEX=0

# 추가 lerobot-replay 인자
REPLAY_EXTRA_ARGS=

# ── dataset-viz 설정 ──────────────────────────────────────────────────────────
# 시각화 모드: local (로컬 뷰어) | distant (WebSocket 서버)
# distant 모드: 클라이언트에서 `rerun ws://HOST:VIZ_WS_PORT` 로 접속
VIZ_MODE=local
VIZ_WS_PORT=9087

# ── Train-Policy 설정 ──────────────────────────────────────────────────────────
# 학습할 Policy(--policy.type)
# (act | diffusion | groot | multi_task_dit | pi0 | pi05 | pi0_fast | rtc | sac
#  sarm | smolvla | tdmpc | vqbet | wall_x | xvla)
POLICY_TYPE=

# 배치 크기(기본 8)
BATCH_SIZE=8

# 총 학습 스텝 수(기본 100,000)
TRAIN_STEPS=100000

# 실험 이름, WandB에서 표시됨(--job_name)
JOB_NAME=

# 산출물 저장 경로(--output_dir)
OUTPUT_DIR=/workspace/outputs/train/${JOB_NAME}

# 가속기 종류(--policy.device)
DEVICE=cuda

# WANDB 사용 여부(--wandb.enable)
WANDB_ENABLE=true

# Policy 레포지토리 ID(--policy.repo_id)
POLICY_REPO_ID=${HF_USER}/my_policy

# 추가 lerobot-train 인자
TRAIN_EXTRA_ARGS="
"
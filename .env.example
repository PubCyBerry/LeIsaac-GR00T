# docker-compose 가 참조하는 환경 변수.
# 이 파일을 `.env` 로 복사한 뒤 값을 채워 넣으면 docker compose up/run 이 자동으로 읽는다.
#
#   Copy-Item .env.example .env
#   notepad .env

# Hugging Face — gated 모델 (예: nvidia/GR00T-N1.6-3B) 접근 시 필수
HF_TOKEN=

# GR00T 정책 서버가 로드할 모델 경로
#   - 사전학습 모델:    nvidia/GR00T-N1.6-3B
#   - 학습 산출물:      /workspace/outputs/gr00t_finetune/<timestamp>/checkpoint-XXXX
GR00T_MODEL_PATH=nvidia/GR00T-N1.6-3B

# GR00T 정책 서버 embodiment tag (학습 시 사용한 tag 와 일치시킬 것)
GR00T_EMBODIMENT_TAG=NEW_EMBODIMENT

# Use case 1: leisaac-sim 컨테이너가 SO101LeaderRemote 로 SUB 할 ZMQ 엔드포인트.
# Windows 호스트에서 scripts/teleop_leader_bridge.ps1 가 PUB 하는 주소.
LEADER_ENDPOINT=tcp://host.docker.internal:5556

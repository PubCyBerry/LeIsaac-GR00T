# 기본: 텍스트 파일은 저장소에 LF로 통일
* text=auto eol=lf

# Windows 전용 실행 파일은 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리는 변환 없음
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pt binary
*.pth binary
*.safetensors binary
*.bin binary
*.pkl binary
*.npy binary
*.npz binary
*.mp4 binary
*.avi binary
*.mov binary
*.zip binary
*.tar binary
*.gz binary
